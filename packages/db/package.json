    "import:geo": "tsx src/import-geo.ts",
    "import:place-names": "tsx src/import-place-names.ts",
    "import:search": "tsx src/import-search.ts",
    "studio": "drizzle-kit studio",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "drizzle-kit": "0.31.10",
    "tsx": "4.21.0",
    "typescript": "5.6.3",
    "vitest": "^4.1.10"

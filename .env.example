# --- PostgreSQL + PostGIS ---
POSTGRES_USER=tabor
POSTGRES_PASSWORD=tabor_dev_password
POSTGRES_DB=tabor
POSTGRES_HOST=localhost
# 5433 para no chocar con un Postgres nativo en 5432
POSTGRES_PORT=54320

# Connection string used by the app and Drizzle
DATABASE_URL=postgres://tabor:tabor_dev_password@localhost:54320/tabor

# --- Meilisearch ---
MEILI_MASTER_KEY=tabor_dev_meili_master_key_change_me
MEILI_HOST=http://localhost:7700

# --- Next.js ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Better-Auth ---
# Generar con: npx @better-auth/cli secret   (o `openssl rand -base64 32`).
# En desarrollo puede omitirse (fallback interno); en producción es OBLIGATORIO.
BETTER_AUTH_SECRET=
# Opcional; si falta se usa NEXT_PUBLIC_SITE_URL
# BETTER_AUTH_URL=http://localhost:3000

